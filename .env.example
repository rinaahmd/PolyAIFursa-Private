# Copy this file to .env (never commit .env) and fill in values for your environment.
# docker-compose.yml reads these to pick which pre-built image tag to pull for each
# service, and to tell the frontend where to reach the agent.
#
# - Local dev: create ./.env from this file; leave the tags unset (or use 0.0.x
#   defaults already baked into docker-compose.yml) and set NEXT_PUBLIC_AGENT_URL
#   to wherever you're running the agent (usually http://localhost:8000).
# - Dev/Prod EC2: each host keeps its own .env at
#   /home/ubuntu/PolyAIFursa-Private/.env. GitHub Actions updates only the one
#   image-tag line for whichever service it just built - see .github/workflows/deploy.yaml.
#   This file is never pushed to Git; it only ever exists on disk on each host/machine.

AGENT_IMAGE_TAG=0.0.1
YOLO_IMAGE_TAG=0.0.1
FRONTEND_IMAGE_TAG=0.0.2
IMG_PROC_MCP_IMAGE_TAG=0.0.1
NEXT_PUBLIC_AGENT_URL=http://localhost:8000
